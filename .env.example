APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

FIREBASE_CREDENTIALS_B64=
FIREBASE_PROJECT_ID=
FIREBASE_FIRESTORE_DATABASE=(default)
FIREBASE_STORAGE_BUCKET=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1-hd

FLUXAI_API_KEY=
FLUXAI_API_ENDPOINT=https://api.fluxapi.ai/api/v1/flux/kontext/generate
FLUXAI_POLL_ENDPOINT=https://api.fluxapi.ai/api/v1/flux/kontext/record-info
FLUXAI_MODEL=flux-kontext-pro
FLUXAI_ENABLE_TRANSLATION=true
FLUXAI_PROMPT_UPSAMPLING=false
FLUXAI_OUTPUT_FORMAT=jpeg
FLUXAI_SAFETY_TOLERANCE=2
FLUXAI_TIMEOUT_SECONDS=90
FLUXAI_JOB_TIMEOUT_SECONDS=600
FLUXAI_POLL_ATTEMPTS=40
FLUXAI_POLL_DELAY_MS=700

VIDEO_JOB_DISPATCH_MODE=process
VIDEO_POST_RATE_LIMIT_PER_MINUTE=5
VIDEO_REMOTION_TIMEOUT_SECONDS=900
VIDEO_REMOTION_CRF=23
VIDEO_REMOTION_X264_PRESET=superfast
VIDEO_REMOTION_CONCURRENCY=2
VIDEO_REMOTION_SCALE=0.9
VIDEO_REMOTION_BUNDLE_CACHE_DIR=/tmp/scrollstop-remotion-bundles
VIDEO_DEFAULT_FPS=24
VIDEO_NODE_BINARY=node
VIDEO_KEEP_WORKDIR_ON_ERROR=false
VIDEO_KEEP_WORKDIR_ON_SUCCESS=false
VIDEO_STATIC_MODE=false
VIDEO_SKIP_STORAGE_UPLOAD=false
VIDEO_MIN_SCENES=3
VIDEO_MAX_SCENES=3
VIDEO_STATIC_IMAGE_PATH=remotion-renderer/assets/static-input.png
VIDEO_STATIC_AUDIO_PATH=

VITE_APP_NAME="${APP_NAME}"
